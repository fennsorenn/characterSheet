{
  // See https://go.microsoft.com/fwlink/?linkid=830387 for launch.json format.
  "version": "0.2.0",
  "configurations": [
    {
      // Run the Vite dev server (npm run dev). Serves the app with HMR at
      // http://localhost:5173; debug the frontend via the browser's own
      // DevTools (Vite emits source maps in dev).
      "name": "Dev: Vite server",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      // Debug the Express static/proxy server. Assumes `npm run build` has
      // produced dist/ (the server warns otherwise).
      "name": "Server: Express",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/server/index.js",
      "cwd": "${workspaceFolder}",
      "skipFiles": ["<node_internals>/**"],
      "console": "integratedTerminal"
    },
    {
      // Run the full Vitest suite once (matches `npm run test`).
      "name": "Test: Vitest run",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/vitest/vitest.mjs",
      "args": ["run"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      // Debug a single Vitest file — the one open in the active editor.
      "name": "Test: Vitest current file",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/vitest/vitest.mjs",
      "args": ["run", "${relativeFile}"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
