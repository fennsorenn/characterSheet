{
  "name": "charactersheet",
  "version": "0.0.0",
  "description": "Modular, calculation-transparent 5e character sheet editor/viewer",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "serve": "node server/index.js",
    "start": "npm run build && npm run serve",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tsconfig/svelte": "^5.0.4",
    "svelte": "^5.19.0",
    "svelte-check": "^4.1.4",
    "typescript": "^5.7.3",
    "vite": "^6.0.11",
    "vitest": "^3.0.4"
  },
  "dependencies": {
    "express": "^4.21.2",
    "fflate": "^0.8.3",
    "pdf-lib": "^1.17.1"
  }
}
